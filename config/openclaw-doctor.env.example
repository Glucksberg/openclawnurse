TELEGRAM_TARGET=""
TELEGRAM_MESSAGE_THREAD_ID=""
# vazio = reutilizar channels.telegram.botToken do ~/.openclaw/openclaw.json quando possivel
TELEGRAM_BOT_TOKEN=""
REPORT_CHANNEL="telegram"
AUTO_DETECT_TELEGRAM_TARGET="true"
TELEGRAM_API_BASE_URL="https://api.telegram.org"
# use um label por host para centralizar varios reports no mesmo bot/grupo
REPORT_INSTANCE_LABEL=""
AUTO_UPDATE="true"
UPDATE_CHANNEL="stable"
TIMEZONE="America/Sao_Paulo"
UPDATE_TIMEOUT="900"
STATUS_TIMEOUT="10"
DOCTOR_TIMEOUT="300"
HEALTH_TIMEOUT_MS="10000"
GATEWAY_WAIT_TIMEOUT="180"
GATEWAY_WAIT_INTERVAL="5"
MAX_CONSECUTIVE_UPDATE_FAILURES="3"
AUTO_REMEDIATE_MISSING_TRANSCRIPTS="true"
AUTO_REMEDIATE_ORPHAN_TRANSCRIPTS="true"
AUTO_REMEDIATE_ALL_AGENTS="false"
AUTO_RESTART_UNHEALTHY_GATEWAY="true"
AUTO_REFRESH_STALE_GATEWAY_SERVICE="true"
AUTO_MIGRATE_PM2_GATEWAY_TO_SYSTEMD="true"
PM2_GATEWAY_APP_NAMES="openclaw-gateway openclaw"
MAX_GATEWAY_RESTARTS_PER_DAY="1"
MAX_GATEWAY_RESTARTS_PER_WINDOW="3"
GATEWAY_RESTART_WINDOW_SECONDS="300"
MAX_DOCTOR_REMEDIATION_PASSES="3"
MAX_ORPHAN_TRANSCRIPTS_PER_RUN="20"
OPENCLAW_CONFIG_FILE="$HOME/.openclaw/openclaw.json"
CONFIG_BACKUP_ENABLED="true"
CONFIG_BACKUP_RETENTION="20"
AUTO_RESTORE_BROKEN_CONFIG="true"
CONFIG_DIFF_MAX_CHARS="1200"
DIAGNOSTIC_LOG_LINES="20"
ENABLE_RUNTIME_SANITY="true"
ENABLE_TELEGRAM_SANITY="true"
ENABLE_GATEWAY_LOG_SCAN="true"
ENABLE_COMMITMENTS_SANITY="true"
ENABLE_SECURITY_AUDIT="true"
SECURITY_AUDIT_DEEP="false"
SECURITY_AUDIT_TIMEOUT="90"
AUTO_FIX_SECURITY_FILE_PERMS="true"
ENABLE_PACKAGE_DRIFT_SANITY="true"
COMMITMENTS_TRACE_SCAN_DAYS="14"
ENABLE_DISK_SANITY="true"
ENABLE_CRON_SANITY="true"
# vazio = detectar pelo ~/.openclaw/openclaw.json quando possivel
EXPECTED_OPENCLAW_MODEL=""
EXPECTED_TELEGRAM_COMMANDS="new reset"
AUTO_REMEDIATE_TELEGRAM_COMMANDS="true"
AUTO_REMEDIATE_EXPECTED_OPENCLAW_MODEL="true"
# "last-run" usa o timestamp do ultimo estado salvo; em primeira execucao usa fallback
GATEWAY_LOG_SINCE="last-run"
GATEWAY_LOG_FALLBACK_SINCE="24 hours ago"
GATEWAY_LOG_MAX_LINES="4000"
DISK_WARN_PERCENT="90"
DISK_CRITICAL_PERCENT="97"
DISK_WARN_MIN_FREE_MB="1024"
DISK_CRITICAL_MIN_FREE_MB="256"
OPENCLAW_LOG_SQLITE_WARN_MB="1024"
DISK_TOP_OFFENDERS_LIMIT="8"
CRON_ISOLATED_MIN_INTERVAL_SECONDS="300"
ORPHAN_TRANSCRIPT_SAFETY_SECONDS="300"
ORPHAN_TRANSCRIPT_ARCHIVE_DIR="$HOME/.local/state/openclawnurse/orphan-transcripts"
OPENCLAW_EXTRA_SCAN_PATHS="$HOME/openclaw/node_modules/.bin/openclaw $HOME/.local/share/pnpm/openclaw $HOME/.npm-global/bin/openclaw"
CHECK_SHELL_ALIASES="true"
# Stale OpenClaw installs are moved to quarantine, not deleted. The active
# OPENCLAW_BIN and the gateway service runtime are protected automatically.
AUTO_REMEDIATE_OPENCLAW_INSTALLATIONS="true"
OPENCLAW_REMEDIABLE_INSTALL_PATHS="$HOME/openclaw/node_modules/.bin/openclaw $HOME/.npm-global/bin/openclaw $HOME/.npm-global/lib/node_modules/openclaw $HOME/.local/share/pnpm/global/5/node_modules/openclaw"
AUTO_REPAIR_OPENCLAW_LAUNCHER="true"
OPENCLAW_LAUNCHER_PATH="$HOME/.local/share/pnpm/openclaw"
AUTO_REMEDIATE_SHELL_OPENCLAW_SHADOWING="true"
AUTO_REMEDIATE_CONFIG_VERSION_DRIFT="true"
AUTO_REFRESH_GATEWAY_SERVICE_AFTER_UPDATE="true"
OPENCLAW_ALERT_CHANNEL="telegram"
OPENCLAW_ALERT_TARGET=""
OPENCLAW_ALERT_THREAD_ID=""
OPENCLAW_ALERT_AGENT_ID="main"
OPENCLAW_ALERT_EVERY=""
OPENCLAW_ALERT_CRON=""
OPENCLAW_ALERT_TZ=""
OPENCLAW_ALERT_JOB_NAME="openclawnurse-alert"
OPENCLAW_ALERT_JOB_DESCRIPTION="Alerta OpenClawNurse quando doctor-state registra incidente ou atividade"
OPENCLAW_ALERT_MIN_INTERVAL_SECONDS="21600"
OPENCLAW_ALERT_RECOVERY="true"
RESTART_MODE="systemd_user"
SYSTEMD_UNIT_NAME="openclaw-gateway.service"
RESTART_COMMAND=""
# Recommended: keep OpenClaw Gateway under systemd user.
# If a legacy exact PM2 app named openclaw-gateway appears, the Nurse can
# remove only that PM2 app and ensure openclaw-gateway.service is enabled/running.
# Recommended on low-memory hosts so repeated CLI runs stay fast:
# NODE_COMPILE_CACHE="/var/tmp/openclaw-compile-cache"
# OPENCLAW_NO_RESPAWN="1"
# For nonstandard bin locations, append extra directories to PATH:
# EXTRA_PATH="$HOME/.local/share/pnpm:/home/linuxbrew/.linuxbrew/bin"
REPORT_MAX_CHARS="3500"
LOG_RETENTION_DAYS="30"
LOG_RETENTION_MB="200"
