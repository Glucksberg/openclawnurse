[Unit]
Description=OpenClaw fleet feed export
After=default.target

[Service]
Type=oneshot
EnvironmentFile=__CONFIG_FILE__
Environment=PATH=%h/.npm-global/bin:%h/.local/bin:%h/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=__INSTALL_DIR__
ExecStart=__INSTALL_DIR__/bin/openclaw-fleet-export-run.sh --config __CONFIG_FILE__
