[Unit]
Description=OpenClawNurse daily doctor run
After=default.target

[Service]
Type=oneshot
EnvironmentFile=__CONFIG_FILE__
Environment=PATH=%h/.npm-global/bin:%h/.local/bin:%h/bin:/home/linuxbrew/.linuxbrew/bin:/usr/local/bin:/usr/bin:/bin
WorkingDirectory=__INSTALL_DIR__
ExecStart=__INSTALL_DIR__/bin/openclaw-doctor.sh --config __CONFIG_FILE__
